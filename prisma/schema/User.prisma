model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  nickname           String
  password           String
  profileImg         String?
  role               UserRole  @default(USER)
  rank               UserRank  @default(NORMAL)
  participationCount Int       @default(0)
  recommendedCount   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  // Relations
  challengeParticipants ChallengeParticipant[]
  draftTranslations     DraftTranslation[]
  translations          Translation[]
  likes                 Like[]
  feedbacks             Feedback[]
  challenges            Challenge[]

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

enum UserRank {
  NORMAL // 일반
  EXPERT // 전문가
}

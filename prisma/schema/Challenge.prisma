model Challenge {
  id                  String       @id @default(uuid())
  field               FieldType
  userId              String
  title               String
  originURL           String
  documentType        DocumentType
  deadline            DateTime
  maxParticipants     Int
  currentParticipants Int
  description         String
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  content             String
  deletedReason       String?
  rejectedReason      String?
  approvalStatus      ApprovalStatus @default(PENDING)//관리자 승인 상태
}


enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FieldType {
  NEXTJS
  MODERNJS
  API
  WEB
  CAREER
}

enum DocumentType {
  Blog
  OFFICIAL
}
